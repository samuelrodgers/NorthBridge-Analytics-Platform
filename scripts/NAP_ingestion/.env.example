# Northbridge Analytics Platform — environment variables for the ingestion pipeline
# Copy this file to .env and fill in your values.

# PostgreSQL connection (used by loader.py, transform.py, live_fx.py)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_name
DB_USER=db_user
DB_PASS=db_password

# Twelve Data API key — used by live_fx.py for real-time FX rates
# Get a free key at https://twelvedata.com
TWELVE_DATA_API_KEY=
